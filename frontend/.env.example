# CCH Frontend Environment Variables Template (CCH 前端環境變數範本)
# Copy this file to .env and fill in the actual values. (將此檔案複製為 .env 並填入實際數值。)

# API Base URL (API 基礎路徑)
# Example: https://api.cch.dimerco.com/v1
VITE_API_BASE_URL=https://api-dev.cch.dimerco.com

# App Environment (應用程式環境: development, production)
VITE_APP_ENV=development
